<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="mm_webforms_form" resource="default" engine="innodb">
        <!-- Salesforce Settings -->
        <column xsi:type="boolean" name="is_salesforce_enabled" nullable="false" default="0" comment="Salesforce integration enabled"/>
        <column xsi:type="int" name="salesforce_email_field_id" unsigned="true" nullable="true" comment="Salesforce Email Override"/>
        <column xsi:type="text" name="salesforce_map_fields_serialized" nullable="true" comment="Salesforce Map Fields in JSON"/>
    </table>

</schema>
